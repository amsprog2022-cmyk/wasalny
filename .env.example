# Flask
SECRET_KEY=change-me-to-a-random-long-string
JWT_SECRET_KEY=another-random-long-string
FLASK_ENV=development

# Database (Railway/Render will provide DATABASE_URL automatically)
DATABASE_URL=sqlite:///wassalny.db

# WhatsApp Cloud API (Meta)
# Get these from https://developers.facebook.com/apps -> WhatsApp -> API Setup
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_BUSINESS_ACCOUNT_ID=1234567890
WHATSAPP_VERIFY_TOKEN=any-string-you-invent-for-webhook-verify
WHATSAPP_APP_SECRET=your-meta-app-secret-for-signature-verification
WHATSAPP_API_VERSION=v21.0

# Initial admin (created on first run if no users exist)
ADMIN_EMAIL=admin@wassalny.com
ADMIN_PASSWORD=change-this-immediately
